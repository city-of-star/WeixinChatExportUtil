{
  "name": "wetrace",
  "version": "2.1.0",
  "description": "微迹 Wetrace - 微信 PC 聊天记录导出工具",
  "main": "electron/main.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "export": "node export.js",
    "start": "electron .",
    "build:hook": "powershell -ExecutionPolicy Bypass -File scripts/build-wexin-hook.ps1",
    "generate-icon": "node scripts/generate-icon.mjs",
    "pack": "electron-builder --dir",
    "predist": "node scripts/generate-icon.mjs && node scripts/ensure-hook-dll.js && node scripts/ensure-sharp-stub.js && node scripts/download-whisper-model.js",
    "download-whisper-model": "node scripts/download-whisper-model.js",
    "postinstall": "node scripts/ensure-sharp-stub.js",
    "dist": "npm run predist && electron-builder --win portable",
    "dist:installer": "npm run predist && electron-builder --win nsis"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "fzstd": "^0.1.1",
    "koffi": "^3.0.2",
    "silk-wasm": "^3.7.1",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "electron": "^35.7.5",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.35.2"
  },
  "build": {
    "extends": "./electron-builder.base.json"
  }
}
