{
  "name": "wetrace",
  "version": "1.0.0",
  "description": "微迹 Wetrace - 微信 PC 聊天记录导出工具",
  "main": "electron/main.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "export": "node export.js",
    "start": "electron .",
    "build:hook": "powershell -ExecutionPolicy Bypass -File scripts/build-wexin-hook.ps1",
    "generate-icon": "node scripts/generate-icon.mjs",
    "pack": "electron-builder --dir",
    "predist": "node scripts/generate-icon.mjs && node scripts/ensure-hook-dll.js",
    "predist:portable": "node scripts/generate-icon.mjs && node scripts/ensure-hook-dll.js",
    "predist:installer": "node scripts/generate-icon.mjs && node scripts/ensure-hook-dll.js",
    "dist": "electron-builder --win portable",
    "dist:portable": "electron-builder --win portable",
    "dist:installer": "electron-builder --win nsis"
  },
  "dependencies": {
    "fzstd": "^0.1.1",
    "koffi": "^3.0.2",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "electron": "^35.7.5",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.35.2"
  },
  "build": {
    "appId": "com.wetrace.exporter",
    "productName": "微迹 Wetrace",
    "icon": "build/icon.ico",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "lib/**/*",
      "assets/**/*",
      "build/logo.svg",
      "build/icon.ico",
      "build/icon.png",
      "export.js",
      "package.json",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "node_modules/sql.js/dist/**",
      "node_modules/koffi/**",
      "assets/dll/**"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "微迹 Wetrace"
    }
  }
}
