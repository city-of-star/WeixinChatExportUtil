{
  "appId": "com.wetrace.exporter",
  "productName": "微迹 Wetrace",
  "icon": "build/icon.ico",
  "directories": {
    "output": "dist"
  },
  "files": [
    "electron/**/*",
    "lib/**/*",
    "assets/dll/**/*",
    "!assets/models/**",
    "build/logo.svg",
    "build/icon.ico",
    "build/icon.png",
    "export.js",
    "package.json",
    "node_modules/**/*"
  ],
  "asarUnpack": [
    "node_modules/sql.js/dist/**",
    "node_modules/koffi/**",
    "node_modules/@xenova/transformers/**",
    "node_modules/silk-wasm/**",
    "assets/dll/**"
  ],
  "extraResources": [
    {
      "from": "assets/models",
      "to": "models",
      "filter": [
        "**/*.json",
        "**/*.txt",
        "**/onnx/encoder_model_quantized.onnx",
        "**/onnx/decoder_model_merged_quantized.onnx",
        "!**/.staging-cache/**",
        "!**/.gitkeep"
      ]
    }
  ],
  "win": {
    "target": [
      {
        "target": "portable",
        "arch": ["x64"]
      }
    ]
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "shortcutName": "微迹 Wetrace"
  }
}
